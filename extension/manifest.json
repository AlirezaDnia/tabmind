{
  "manifest_version": 3,
  "name": "TabMind",
  "version": "1.0.0",
  "description": "AI browser memory",

  "permissions": [
    "contextMenus",
    "activeTab",
    "storage"
  ],

  "background": {
    "service_worker": "background.js"
  },
  
  "action": {
    "default_popup": "popup.html"
  }

}